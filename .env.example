# Port this service listens on
PORT=3015

# Allowed CORS origin (e.g. https://app.example.com). Defaults to *
CORS_ORIGIN=*

# Public base URL of this service, used to build the MCP url in token responses.
# If empty, falls back to http://localhost:${PORT}
PUBLIC_BASE_URL=

# Firebase project id used by the Admin SDK
FIREBASE_PROJECT_ID=excalidraw-team

# Absolute path to the Firebase service account JSON for applicationDefault()
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/service-account.json

# Firebase Web API key (the apiKey "AIzaSy..." from the web SDK config).
# Required to exchange the bot's custom token for an ID token.
FIREBASE_WEB_API_KEY=AIzaSy...

# Collaboration (socket.io) server URL the bot connects to
WS_SERVER_URL=http://localhost:3002

# Directory where image files are stored (replaces Firebase Storage)
DATA_DIR=./data

# Optional shared secret reserved for future internal endpoints
INTERNAL_SECRET=
